# --- AI APIs ---
ANTHROPIC_API_KEY=sk-ant-...
FAL_KEY=...

# --- Cloudflare R2 (video storage) ---
# Create a bucket in your Cloudflare dashboard → R2.
# Generate an API token with read/write access to the bucket.
# The public URL is the "Public Bucket URL" from the bucket settings.
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=we-were-here-briefly
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# --- Vercel Postgres (metadata database) ---
# Link a Postgres database to your Vercel project.
# Vercel auto-populates this in production.
# For local dev, copy the connection string from the Vercel dashboard.
POSTGRES_URL=postgres://user:pass@host:5432/dbname
